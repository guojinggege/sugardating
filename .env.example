# Lumina 环境变量样板 — 真实值放在 .env / .env.local / Vercel Dashboard,不要提交
# Neon 的连接字符串有两种形态,Prisma 各跑一个:
#   - DATABASE_URL: pooler(PgBouncer)端点,query 走它,带 ?pgbouncer=true
#   - DIRECT_URL:   直连端点,migration / introspection 必须走它
#
# Neon Dashboard → 项目 → Connection Details:
#   - "Pooled connection" → DATABASE_URL
#   - "Direct connection" → DIRECT_URL

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.<region>.aws.neon.tech/lumina?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.<region>.aws.neon.tech/lumina?sslmode=require"
