// Lumina — Prisma schema (SQLite, local-dev)
// 仅核心几张表：User / Creator / Category / Region / Work / TierPlan

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String
  role        String       @default("creator") // user | creator | admin
  createdAt   DateTime     @default(now())
  creator     Creator?
  memberships Membership[]
}

model Category {
  id       Int       @id @default(autoincrement())
  slug     String    @unique
  label    String
  creators Creator[]
}

model Region {
  id       Int       @id @default(autoincrement())
  label    String    @unique
  creators Creator[]
}

model Creator {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  specialty  String
  price      String   // 展示用,如 "S$6"
  tier       String   // basic | pro | elite
  subs       Int      @default(0)
  followers  Int      @default(0)
  worksCount Int      @default(0)
  bio        String?
  userId     String   @unique
  categoryId Int
  regionId   Int
  createdAt  DateTime @default(now())

  user     User       @relation(fields: [userId], references: [id])
  category Category   @relation(fields: [categoryId], references: [id])
  region   Region     @relation(fields: [regionId], references: [id])
  works    Work[]
  tiers    TierPlan[]
  tips     Tip[]
  comments Comment[]
}

model Work {
  id         String   @id @default(cuid())
  title      String
  type       String   @default("image") // image | video
  visibility String   @default("public") // public | subscriber
  creatorId  String
  createdAt  DateTime @default(now())

  creator Creator @relation(fields: [creatorId], references: [id])
}

model TierPlan {
  id        Int    @id @default(autoincrement())
  name      String // basic | pro | elite
  label     String // 入门 / 进阶 / Elite
  price     String // "S$6"
  benefits  String // JSON 字符串(SQLite 无原生数组)
  creatorId String

  creator Creator @relation(fields: [creatorId], references: [id])
}

model Tip {
  id        String   @id @default(cuid())
  amount    Int      // 整数(单位 S$),不接真实支付,只记录
  message   String?  // 可选留言
  creatorId String
  createdAt DateTime @default(now())

  creator Creator @relation(fields: [creatorId], references: [id])

  @@index([creatorId, createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  authorName String
  content    String
  creatorId  String
  createdAt  DateTime @default(now())

  creator Creator @relation(fields: [creatorId], references: [id])

  @@index([creatorId, createdAt])
}

// 平台会员套餐 — 3 等级 × 4 周期 = 12 行
model MembershipPlan {
  id        String   @id @default(cuid())
  tier      String   // basic | premium | elite
  period    String   // week | month | quarter | year
  price     Int      // 分(SGD cents)
  currency  String   @default("SGD")
  benefits  String   // JSON 字符串(SQLite 无 array)
  bestValue Boolean  @default(false)
  sortKey   Int      @default(0)
  createdAt DateTime @default(now())

  memberships Membership[]

  @@unique([tier, period])
}

// 用户开通的会员 — userId 暂时可空,待 auth 接入后回填
model Membership {
  id        String   @id @default(cuid())
  userId    String?
  planId    String
  startsAt  DateTime @default(now())
  endsAt    DateTime
  status    String   @default("active") // active | expired | cancelled
  createdAt DateTime @default(now())

  user User?           @relation(fields: [userId], references: [id])
  plan MembershipPlan  @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@index([planId])
}
